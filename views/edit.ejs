<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script> 
   
</head>
<body>
      <div class = "main w-full min-h-screen bg-zinc-900 text-white">

        <div class="px-5 py-3 ">
        
          <form action="/edit" method="post">
             <input class="block w-1/4 bg-zinc-800 text-zinc-300 px-5 py-2 rounded-md "  type="text" placeholder="Previous name" name="previous" value="<%= filename %>">
             <input class="block w-1/4 bg-zinc-800 text-zinc-300 px-5 py-2 rounded-md flex mt-3"  type="text" placeholder="Enter new filename" name="Newname">
             <input class="mt-2 bg-yellow-600 px-5 py-2 rounded-md" type="submit" value="Update">
          </form>
           
            
    
        </div>
   
      </div>

     
</body>
</html>